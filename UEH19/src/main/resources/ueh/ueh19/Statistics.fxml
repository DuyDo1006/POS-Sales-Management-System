<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ueh.ueh19.StatisticsController" stylesheets="@styles.css">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="14.0" layoutY="14.0" prefHeight="580.0" prefWidth="780.0" spacing="20.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0" styleClass="root">
         <children>
            <Label text="Thống kê Doanh thu">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <BarChart fx:id="barChart" title="Top 5 Sản phẩm Bán chạy nhất" VBox.vgrow="ALWAYS">
              <xAxis>
                <CategoryAxis side="BOTTOM" />
              </xAxis>
              <yAxis>
                <NumberAxis side="LEFT" />
              </yAxis>
            </BarChart>
            <Button fx:id="exportPdfButton" mnemonicParsing="false" onAction="#handleExportPdf" prefHeight="40.0" prefWidth="200.0" text="Xuất Báo cáo PDF" styleClass="btn-gray" />
         </children>
      </VBox>
   </children>
</AnchorPane>